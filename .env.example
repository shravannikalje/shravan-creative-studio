# Auth mode: password or google
AUTH_MODE=password

# Website login password
ACCESS_PASSWORD=replace_with_access_password

# Admin panel password
ADMIN_PASSWORD=replace_with_admin_password

# IMPORTANT: set a strong random secret in production
SESSION_SECRET=replace_with_long_random_secret

# Google mode optional (needed only when AUTH_MODE=google)
GOOGLE_CLIENT_ID=
ALLOWED_EMAILS=
ADMIN_EMAILS=

# Custom section (used for google mode allowlist)
CUSTOM_SECTION_EMAILS=

# Custom section rules
CUSTOM_SECTION_PHONE_ONLY=true
CUSTOM_SECTION_REQUIRE_TRUSTED_DEVICE=true

# Optional for cloud storage path (if you later add support)
# DATA_DIR=
